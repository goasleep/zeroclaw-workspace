{
  "name": "zeroclaw-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Desktop workspace client for ZeroClaw — connect local or remote",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{html,json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{html,json,ts}\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "~6.5.0",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@uiw/react-codemirror": "~4.25.10",
    "lucide-react": "~1.17.0",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "react-markdown": "~10.1.0",
    "react-router-dom": "~7.17.0",
    "rehype-highlight": "~7.0.2",
    "remark-gfm": "~4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "~4.3.0",
    "@tauri-apps/cli": "~2.11.2",
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.2",
    "openapi-typescript": "~7.13.0",
    "prettier": "^3.8.4",
    "tailwindcss": "~4.3.0",
    "typescript": "~5.9.0",
    "vite": "~8.0.16"
  }
}
