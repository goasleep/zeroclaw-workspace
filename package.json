{
  "name": "zeroclaw-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "description": "Desktop workspace client for ZeroClaw — connect local or remote",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build",
    "desktop:build": "tauri build",
    "desktop:dev": "tauri dev",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{html,json,js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{html,json,js,ts}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "rust:check": "pnpm rust:fmt && pnpm rust:clippy && pnpm rust:test",
    "rust:clippy": "cd src-tauri && cargo clippy --all-targets -- -D warnings",
    "rust:fmt": "cd src-tauri && cargo fmt --all -- --check",
    "rust:test": "cd src-tauri && cargo test --all-targets",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "~6.5.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.0",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@uiw/react-codemirror": "~4.25.10",
    "lucide-react": "~1.17.0",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "react-markdown": "~10.1.0",
    "react-router-dom": "~7.17.0",
    "rehype-highlight": "~7.0.2",
    "remark-gfm": "~4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "~4.3.0",
    "@tauri-apps/cli": "~2.11.2",
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "openapi-typescript": "~7.13.0",
    "prettier": "^3.8.4",
    "tailwindcss": "~4.3.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.61.1",
    "vite": "~8.0.16"
  }
}
