{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroClaw Workspace",
  "version": "0.1.0",
  "identifier": "ai.zeroclawlabs.workspace",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5183",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZeroClaw Workspace",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 540,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "ZeroClaw desktop workspace",
    "longDescription": "Connect to a local or remote ZeroClaw gateway from one workspace UI."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["zeroclaw"]
      }
    }
  }
}
